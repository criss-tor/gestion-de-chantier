import { useState, useEffect } from 'react';
import { useEmployeeContext } from '@/contexts/EmployeeContext';
import { HourCategory } from '@/types/employee';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogFooter,
} from '@/components/ui/dialog';
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '@/components/ui/table';
import { Badge } from '@/components/ui/badge';
import { Plus, Trash2, Clock, Percent, Pencil } from 'lucide-react';
import { format, startOfWeek, addDays, parseISO, isSameMonth } from 'date-fns';

export default function Heures() {
  const {
    employees,
    chantiers,
    timeEntries,
    hourCategories,
    addTimeEntry,
    deleteTimeEntry,
    addHourCategory,
    deleteHourCategory,
    updateHourCategory,
    currentEmployeeId,
  } = useEmployeeContext();

  const [showAdd, setShowAdd] = useState(false);
  const [editingCat, setEditingCat] = useState<HourCategory | null>(null);
  const [nom, setNom] = useState('');
  const [pourcentage, setPourcentage] = useState('0');

  const [selectedEmployeeId, setSelectedEmployeeId] = useState(currentEmployeeId ?? employees[0]?.id ?? '');
  const [selectedChantierId, setSelectedChantierId] = useState(chantiers[0]?.id ?? '');
  const [selectedHourCategoryId, setSelectedHourCategoryId] = useState(hourCategories[0]?.id ?? '');
  const [entryDate, setEntryDate] = useState(new Date().toISOString().slice(0, 10));
  const [entryHeures, setEntryHeures] = useState('8');
  const [entryDesc, setEntryDesc] = useState('');

  useEffect(() => {
    setSelectedEmployeeId(currentEmployeeId ?? employees[0]?.id ?? '');
  }, [currentEmployeeId, employees]);

  const handleSave = () => {
    if (!nom) return;
    if (editingCat) {
      updateHourCategory(editingCat.id, { nom, pourcentage: parseFloat(pourcentage) || 0 });
    } else {
      addHourCategory({ nom, pourcentage: parseFloat(pourcentage) || 0 });
    }
    setNom('');
    setPourcentage('0');
    setEditingCat(null);
    setShowAdd(false);
  };

  const handleAddEntry = () => {
    if (!selectedEmployeeId || !entryDate || !entryHeures) return;
    addTimeEntry({
      employeeId: selectedEmployeeId,
      chantierId: selectedChantierId || undefined,
      date: entryDate,
      heures: parseFloat(entryHeures),
      description: entryDesc || undefined,
      hourCategoryId: selectedHourCategoryId || undefined,
    });
    setEntryHeures('8');
    setEntryDesc('');
  };

  const openEdit = (cat: HourCategory) => {
    setEditingCat(cat);
    setNom(cat.nom);
    setPourcentage(String(cat.pourcentage));
    setShowAdd(true);
  };

  const entriesForEmployee = timeEntries.filter((e) => e.employeeId === selectedEmployeeId);

  const today = new Date();
  const weekStart = startOfWeek(today, { weekStartsOn: 1 });
  const weekDays = Array.from({ length: 7 }).map((_, i) => addDays(weekStart, i));
  const hoursByDay = weekDays.map((day) => {
    const dayKey = format(day, 'yyyy-MM-dd');
    const total = entriesForEmployee
      .filter((e) => e.date === dayKey)
      .reduce((sum, e) => sum + e.heures, 0);
    return { day, total };
  });
  const weekTotal = hoursByDay.reduce((sum, day) => sum + day.total, 0);
  const monthTotal = entriesForEmployee
    .filter((e) => isSameMonth(parseISO(e.date), today))
    .reduce((sum, e) => sum + e.heures, 0);

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold">Saisie des heures</h1>
          <p className="text-muted-foreground">Enregistrez vos heures rapidement (chantier, catégorie, date).</p>
        </div>
        {currentEmployeeId && (
          <div className="text-sm text-muted-foreground">
            Connecté en tant que : <span className="font-semibold text-primary">{employees.find((e) => e.id === currentEmployeeId)?.prenom ?? ''} {employees.find((e) => e.id === currentEmployeeId)?.nom ?? ''}</span>
          </div>
        )}
      </div>

      {currentEmployeeId && (
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <Card>
            <CardHeader>
              <CardTitle>Heures cette semaine</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold">{weekTotal.toFixed(1)} h</div>
              <div className="text-sm text-muted-foreground">Semaine du {format(weekStart, 'd MMM yyyy')}</div>
              <div className="mt-4 grid grid-cols-7 gap-2">
                {hoursByDay.map(({ day, total }) => (
                  <div key={day.toISOString()} className="text-center">
                    <div className="text-xs text-muted-foreground">{format(day, 'E')}</div>
                    <div className="text-sm font-semibold">{total.toFixed(1)}h</div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
          <Card>
            <CardHeader>
              <CardTitle>Heures ce mois</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold">{monthTotal.toFixed(1)} h</div>
              <div className="text-sm text-muted-foreground">{format(today, 'MMMM yyyy')}</div>
            </CardContent>
          </Card>
        </div>
      )}

      <Card>
        <CardHeader>
          <CardTitle>Nouvelle entrée</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="grid gap-4">
            <div className="grid md:grid-cols-2 gap-4">
              <div className="grid gap-2">
                <Label>Employé</Label>
                <select
                  className="input"
                  value={selectedEmployeeId}
                  onChange={(e) => setSelectedEmployeeId(e.target.value)}
                >
                  <option value="">Sélectionner un employé</option>
                  {employees.map((emp) => (
                    <option key={emp.id} value={emp.id}>{emp.prenom} {emp.nom}</option>
                  ))}
                </select>
              </div>

              <div className="grid gap-2">
                <Label>Chantier</Label>
                <select
                  className="input"
                  value={selectedChantierId}
                  onChange={(e) => setSelectedChantierId(e.target.value)}
                >
                  <option value="">(Aucun)</option>
                  {chantiers.map((ch) => (
                    <option key={ch.id} value={ch.id}>{ch.nom}</option>
                  ))}
                </select>
              </div>
            </div>

            <div className="grid md:grid-cols-3 gap-4">
              <div className="grid gap-2">
                <Label>Date</Label>
                <Input type="date" value={entryDate} onChange={(e) => setEntryDate(e.target.value)} />
              </div>
              <div className="grid gap-2">
                <Label>Heures</Label>
                <Input type="number" step="0.25" value={entryHeures} onChange={(e) => setEntryHeures(e.target.value)} />
              </div>
              <div className="grid gap-2">
                <Label>Catégorie</Label>
                <select
                  className="input"
                  value={selectedHourCategoryId}
                  onChange={(e) => setSelectedHourCategoryId(e.target.value)}
                >
                  <option value="">Sélectionner</option>
                  {hourCategories.map((cat) => (
                    <option key={cat.id} value={cat.id}>{cat.nom}</option>
                  ))}
                </select>
              </div>
            </div>

            <div className="grid gap-2">
              <Label>Commentaire (optionnel)</Label>
              <Input value={entryDesc} onChange={(e) => setEntryDesc(e.target.value)} placeholder="Ex. Pose de carrelage" />
            </div>

            <div className="flex justify-end">
              <Button onClick={handleAddEntry} disabled={!selectedEmployeeId || !entryDate || !entryHeures}>
                <Plus className="mr-2 h-4 w-4" />
                Enregistrer
              </Button>
            </div>
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle>Mes entrées</CardTitle>
        </CardHeader>
        <CardContent>
          {entriesForEmployee.length === 0 ? (
            <p className="text-sm text-muted-foreground">Aucune entrée pour l'employé sélectionné.</p>
          ) : (
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Date</TableHead>
                  <TableHead>Chantier</TableHead>
                  <TableHead>Categorie</TableHead>
                  <TableHead className="text-right">Heures</TableHead>
                  <TableHead>Description</TableHead>
                  <TableHead className="w-[50px]"></TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {entriesForEmployee.map((entry) => {
                  const chantier = chantiers.find((c) => c.id === entry.chantierId);
                  const category = hourCategories.find((c) => c.id === entry.hourCategoryId);
                  return (
                    <TableRow key={entry.id}>
                      <TableCell>{entry.date}</TableCell>
                      <TableCell>{chantier?.nom ?? 'Bureau'}</TableCell>
                      <TableCell>
                        {category?.nom ? (
                          <span className={
                            category.nom === 'Absent' || category.nom === 'Congé'
                              ? 'text-amber-600 font-semibold'
                              : ''
                          }>
                            {category.nom}
                          </span>
                        ) : (
                          '-'
                        )}
                      </TableCell>
                      <TableCell className="text-right">{entry.heures.toFixed(1)} h</TableCell>
                      <TableCell>{entry.description ?? '-'}</TableCell>
                      <TableCell>
                        <Button variant="ghost" size="icon" onClick={() => deleteTimeEntry(entry.id)}>
                          <Trash2 className="h-4 w-4 text-destructive" />
                        </Button>
                      </TableCell>
                    </TableRow>
                  );
                })}
              </TableBody>
            </Table>
          )}
        </CardContent>
      </Card>

      {!currentEmployeeId && (
        <>
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-2xl font-bold">Catégories d'heures</h1>
              <p className="text-muted-foreground">
                Gérez les types d'heures et leurs majorations
              </p>
            </div>
            <Button onClick={() => setShowAdd(true)}>
              <Plus className="mr-2 h-4 w-4" />
              Ajouter une catégorie
            </Button>
          </div>

          <div className="rounded-xl border bg-card overflow-hidden">
            <Table>
              <TableHeader>
                <TableRow className="bg-muted/50 hover:bg-muted/50">
                  <TableHead className="font-semibold">Catégorie</TableHead>
                  <TableHead className="font-semibold text-right">Pourcentage</TableHead>
                  <TableHead className="font-semibold text-right">Multiplicateur</TableHead>
                  <TableHead className="w-[70px]"></TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {hourCategories.map((cat) => (
                  <TableRow key={cat.id}>
                    <TableCell>
                      <div className="flex items-center gap-3">
                        <div className="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center">
                          <Clock className="h-5 w-5 text-primary" />
                        </div>
                        <span className="font-medium">{cat.nom}</span>
                      </div>
                    </TableCell>
                    <TableCell className="text-right">
                      <Badge
                        variant="outline"
                        className={
                          cat.pourcentage > 0
                            ? 'border-green-500/30 bg-green-500/10 text-green-700'
                            : cat.pourcentage < 0
                            ? 'border-red-500/30 bg-red-500/10 text-red-700'
                            : 'border-muted-foreground/30'
                        }
                      >
                        {cat.pourcentage > 0 ? '+' : ''}{cat.pourcentage}%
                      </Badge>
                    </TableCell>
                    <TableCell className="text-right font-medium">
                      ×{(1 + cat.pourcentage / 100).toFixed(2)}
                    </TableCell>
                    <TableCell>
                      <div className="flex items-center gap-1">
                        <Button variant="ghost" size="icon" onClick={() => openEdit(cat)}>
                          <Pencil className="h-4 w-4 text-muted-foreground" />
                        </Button>
                        <Button variant="ghost" size="icon" onClick={() => deleteHourCategory(cat.id)}>
                          <Trash2 className="h-4 w-4 text-destructive" />
                        </Button>
                      </div>
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </div>
        </>
      )}

      <Dialog open={showAdd} onOpenChange={(open) => { setShowAdd(open); if (!open) setEditingCat(null); }}>
        <DialogContent className="sm:max-w-[400px]">
          <DialogHeader>
            <DialogTitle>{editingCat ? 'Modifier la catégorie' : 'Nouvelle catégorie d\'heures'}</DialogTitle>
          </DialogHeader>
          <div className="grid gap-4 py-4">
            <div className="grid gap-2">
              <Label>Nom</Label>
              <Input value={nom} onChange={(e) => setNom(e.target.value)} placeholder="Ex: Heures supplémentaires" />
            </div>
            <div className="grid gap-2">
              <Label>Pourcentage de majoration / réduction</Label>
              <div className="flex items-center gap-2">
                <Input
                  type="number"
                  value={pourcentage}
                  onChange={(e) => setPourcentage(e.target.value)}
                  placeholder="25"
                />
                <Percent className="h-4 w-4 text-muted-foreground" />
              </div>
              <p className="text-xs text-muted-foreground">
                Ex: 25 = +25% du coût horaire, -10 = -10% du coût horaire
              </p>
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => { setShowAdd(false); setEditingCat(null); }}>Annuler</Button>
            <Button onClick={handleSave} disabled={!nom}>{editingCat ? 'Enregistrer' : 'Ajouter'}</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}
